# ══════════════════════════════════════════════════════════════
# Falcon Fast Delivery Frontend — Environment Variables
# Copy to .env.local — NEVER commit this file
# ══════════════════════════════════════════════════════════════

# ── Backend API URL ───────────────────────────────────────────
# This is exposed to the browser (NEXT_PUBLIC_ prefix required)
# Point to your Railway backend URL in production
NEXT_PUBLIC_API_URL=https://backend-service.railway.app

# ── Development ────────────────────────────────────────────────
# For local development:
# NEXT_PUBLIC_API_URL=http://localhost:3001

# ──────────────────────────────────────────────────────────────
# SECURITY WARNING: DO NOT add these to frontend env:
# ──────────────────────────────────────────────────────────────
# ❌ DATABASE_URL
# ❌ JWT_SECRET
# ❌ SUPABASE_SERVICE_KEY
# ❌ Any other backend secrets
#
# Anything with NEXT_PUBLIC_ is bundled into browser JavaScript
# and visible to all users. Only add truly public variables.
# ──────────────────────────────────────────────────────────────
